 "doc_type": "Kidu Profile",
 "docstatus": 0,
 "doctype": "Print Format",
 "font_size": 14,
 "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<style>\n    body {\n        font-size: 16px;\n    }\n\n    h5 {\n        font-weight: bold;\n    }\n\n    .container-1,\n    .container-2,\n    .container-3 {\n        /*border: 2px solid #D4D4D4;*/\n        padding: 30px;\n        margin-top: 20px;\n    }\n\n    .cv-field {\n        display: flex;\n        margin-bottom: 8px;\n    }\n\n    .field-label {\n        font-weight: bold;\n        min-width: 180px;\n    }\n\n    .field-value {\n        flex-grow: 1;\n    }\n\n    .table-row {\n        display: flex;\n        padding: 8px 0;\n    }\n\n    .table-header {\n        font-weight: bold;\n    }\n\n    .table-cell {\n        flex: 1;\n        padding: 0 5px;\n    }\n    \n    .custom-dark th {\n        color: #000 !important;\n        font-weight: bold;\n    }\n</style>\n\n<head>\n    <h1 class=\"col-12 text-center\" style=\"margin-bottom: 0px;\">\n        Profile\n    </h1>\n\n</head>\n\n<body>\n    <div class=\"container-1\">\n        {%if doc.application_mode in ['Individual','Individual and Member']%}\n            <img src=\"{{doc.photo or ''}}\" style=\"width:150px; height:150px; float:right; margin-left:20px; margin-bottom:20px;\">\n        {%endif%}\n        \n        {%if doc.application_mode in ['Individual','Individual and Member']%}\n            <div class=\"cv-field\">\n                <div class=\"field-label\">Name :</div>\n                <div class=\"field-value\">{{doc.full_name or 'N/A'}}</div>\n            </div>\n        {%endif%}\n        \n        {%if doc.application_mode in ['Organization']%}\n            <div class=\"cv-field\">\n                <div class=\"field-label\">Organization Name :</div>\n                <div class=\"field-value\">{{doc.organization or 'N/A'}}</div>\n            </div>\n        {%endif%}\n        \n        {%if doc.application_mode in ['Individual','Individual and Member']%}\n            <div class=\"cv-field\">\n                <div class=\"field-label\">CID :</div>\n                <div class=\"field-value\">{{doc.cid or 'N/A'}}</div>\n            </div>\n        {%endif%}\n\n        {%if doc.application_mode in ['Individual','Individual and Member']%}\n            <div class=\"cv-field\">\n                <div class=\"field-label\">Date of Birth :</div>\n                <div class=\"field-value\">{{doc.dob or 'N/A'}}</div>\n            </div>\n        {%endif%}\n        \n        {%if doc.application_mode in ['Individual','Individual and Member']%}\n            <div class=\"cv-field\">\n                <div class=\"field-label\">Gender :</div>\n                <div class=\"field-value\">{{doc.gender or 'N/A'}}</div>\n            </div>\n        {%endif%}\n        \n        {%if doc.application_mode in ['Individual','Individual and Member']%}\n            <div class=\"cv-field\">\n                <div class=\"field-label\">Mobile No :</div>\n                <div class=\"field-value\">{{doc.contact_no or 'N/A'}}\n                {% if doc.emergency_contact_no %}\n                    /{{ doc.emergency_contact_no }}\n                     {% endif %}\n                </div>\n            </div>\n        {%endif%}\n        \n        {%if doc.application_mode in ['Individual','Individual and Member','Organization']%}\n            <div class=\"cv-field\">\n                <div class=\"field-label\">Dzongkhag :</div>\n                <div class=\"field-value\">{{doc.dzongkhag or 'N/A'}}</div>\n            </div>\n        {%endif%}\n        \n        {%if doc.application_mode in ['Individual','Individual and Member','Organization']%}\n            <div class=\"cv-field\">\n                <div class=\"field-label\">Gewog :</div>\n                <div class=\"field-value\">{{doc.gewog or 'N/A'}}</div>\n            </div>\n        {%endif%}\n        \n        {%if doc.application_mode in ['Individual','Individual and Member','Organization']%}\n            <div class=\"cv-field\">\n                <div class=\"field-label\">Village :</div>\n                <div class=\"field-value\">{{doc.village or 'N/A'}}</div>\n            </div>\n        {%endif%}\n        \n        {% if doc.application_channel and doc.application_channel == 'En route' %}\n            <div class=\"cv-field\">\n                <div class=\"field-label\">RC :</div>\n                <div class=\"field-value\">{{ doc.rc or 'N/A' }}</div>\n            </div>\n        {% endif %}\n        \n        <div class=\"cv-field\" style=\"padding-top:20px\">\n            <div class=\"field-label\">Appeal Reason :</div>\n            <div class=\"field-value\">{{doc.appeal_reason or 'N/A'}}</div>\n        </div>\n\n        <div class=\"cv-field\" style=\"padding-top:20px\">\n            <div class=\"field-label\">Background/Case :</div>\n        </div>\n        \n        <div>{{doc.brief_background or 'N/A'}}</div>\n        \n        {% if doc.member | length > 0 %}\n            <h5 class=\"mt-3 mb-2\">Kidu Applicants List</h5>\n            <table class=\"table table-bordered table-sm\" style=\"border-collapse: collapse; width:100%;\">\n                <thead class=\"custom-dark\">\n                    <tr>\n                        <th style=\"border: 1px solid #888; padding: 1px;\">Name</th>\n                        <th style=\"border: 1px solid #888; padding: 1px;\">CID</th>\n                        <th style=\"border: 1px solid #888; padding:1px;\">DOB</th>\n                        <th style=\"border: 1px solid #888; padding: 1px;\">Gender</th>\n                        <th style=\"border: 1px solid #888; padding: 1px;\">Contact No</th>\n                        <th style=\"border: 1px solid #888; padding: 1px;\">Dzongkhag, Gewog, Village</th>\n                        <th style=\"border: 1px solid #888; padding: 1px;\">Photo</th>\n                    </tr>\n                </thead>\n                <tbody>\n                    {% for m in doc.member %}\n                        <tr>\n                            <td style=\"border: 1px solid #888; padding: 1px;\">{{ m.full_name or 'N/A' }}</td>\n                            <td style=\"border: 1px solid #888; padding: 1px;\">{{ m.cid or 'N/A' }}</td>\n                            <td style=\"border: 1px solid #888; padding: 1px;\">{{ m.dob or 'N/A' }}</td>\n                            <td style=\"border: 1px solid #888; padding: 1px;\">{{ m.gender or 'N/A' }}</td>\n                            <td style=\"border: 1px solid #888; padding: 1px;\">{{ m.contact_no or 'N/A' }}</td>\n                            <td style=\"border: 1px solid #888; padding: 1px;\">{{ m.dzongkhag}},<br>{{m.gewog}},<br>{{m.village }}</td>\n                            <td style=\"border: 1px solid #888; padding: 1px; text-align:center;\">\n                                {% if m.photo %}\n                                    <img src=\"{{ m.photo }}\" style=\"width:50px; height:50px; object-fit:cover;\">\n                                {% else %}\n                                    <span class=\"text-muted\">N/A</span>\n                                {% endif %}\n                            </td>\n                        </tr>\n                    {% endfor %}\n                </tbody>\n            </table>\n        {% endif %}\n        \n        {% if doc.kidu_type not in ['Travel Document','Census','Medical Referral','Miscellaneous'] %}\n            {% if doc.application_mode not in ['Organization','Group'] %}\n                <h5 class=\"mt-3 mb-2\">Family Tree</h5>\n                <table class=\"table table-bordered table-sm\" style=\"border-collapse: collapse; width:100%;\">\n                    <thead class=\"custom-dark\">\n                        <tr>\n                            <th style=\"border: 1px solid #888; padding: 1px;\">Name</th>\n                            <th style=\"border: 1px solid #888; padding: 1px;\">CID</th>\n                            <th style=\"border: 1px solid #888; padding:1px;\">Dob</th>\n                        </tr>\n                    </thead>\n        \n                    <tbody> \n                        {% set familytree = doc.get_family_tree_details() %}\n    \n                            {% if familytree and familytree|length > 0 %}\n                                {% for m in familytree %}\n                                    <tr>\n                                        <td style=\"border: 1px solid #888; padding: 1px;\">{{ m.fullName or 'N/A' }}</td>\n                                        <td style=\"border: 1px solid #888; padding: 1px;\">{{ m.cid or 'N/A' }}</td>\n                                        <td style=\"border: 1px solid #888; padding: 1px;\">{{ m.dob or 'N/A' }}</td>\n                                    </tr>\n                                {% endfor %}\n                            {% else %}\n                                <tr>\n                                    <td colspan=\"3\" style=\"text-align: center; border: 1px solid #888; padding: 5px;\">\n                                        No data found.\n                                    </td>\n                                </tr>\n                            {% endif %}\n                    </tbody>\n                </table>\n            \n                <h5 class=\"mt-3 mb-2\">Family Landholding</h5>\n                <table class=\"table table-bordered table-sm\" style=\"border-collapse: collapse; width:100%;\">\n                    <thead class=\"custom-dark\">\n                        <tr>\n                            <th style=\"border: 1px solid #888; padding: 1px;\">CID</th>\n                            <th style=\"border: 1px solid #888; padding: 1px;\">Owner Name</th>\n                            <th style=\"border: 1px solid #888; padding:1px;\">Plot Name</th>\n                            <th style=\"border: 1px solid #888; padding: 1px;\">Plot Net Area</th>\n                            <th style=\"border: 1px solid #888; padding: 1px;\">Thram Number</th>\n                            <th style=\"border: 1px solid #888; padding: 1px;\">Gewog / Thromde / Village</th>\n                            <th style=\"border: 1px solid #888; padding: 1px;\">Land Location</th>\n                        </tr>\n                    </thead>\n                    \n        \n                    <tbody>\n                        {% set family_land_details = doc.get_family_land_details() %}\n                        {% if family_land_details %}\n                            {% for family in family_land_details %}\n                                {% for land in family.landDetail %}\n                                <tr>\n                                    <td style=\"border: 1px solid #888; padding: 1px;\">{{ land.ownerName or 'N/A' }}</td>\n                                    <td style=\"border: 1px solid #888; padding: 1px;\">{{ land.ownerCid or 'N/A' }}</td>\n                                    <td style=\"border: 1px solid #888; padding: 1px;\">{{ land.plotName or 'N/A' }}</td>\n                                    <td style=\"border: 1px solid #888; padding: 1px;\">{{ land.plotNetArea or 'N/A' }}</td>\n                                    <td style=\"border: 1px solid #888; padding: 1px;\">{{ land.thramNumber or 'N/A' }}</td>\n                                    <td style=\"border: 1px solid #888; padding: 1px;\">{{ land.gewogOrThromdeVillage}}</td>\n                                    <td style=\"border: 1px solid #888; padding: 1px;\">{{land.landLocationFlag}}\n                                    </td>\n                                </tr>\n                                {% endfor %}\n                            {% endfor %}\n                            {% else %}\n                            <tr>\n                                <td colspan=\"7\" style=\"text-align: center; border: 1px solid #888; padding: 5px;\">\n                                    No data found.\n                                </td>\n                            </tr>\n                            {% endif %}\n                    </tbody>\n                </table>\n                \n                <h5 class=\"mt-3 mb-2\">Shareholding</h5>\n                <table class=\"table table-bordered table-sm\" style=\"border-collapse: collapse; width:100%;\">\n                    <thead class=\"custom-dark\">\n                        <tr>\n                            <th style=\"border: 1px solid #888; padding: 1px;\">Firm Name</th>\n                            <th style=\"border: 1px solid #888; padding: 1px;\">Unit</th>\n                            <th style=\"border: 1px solid #888; padding:1px;\">Type</th>\n                            <th style=\"border: 1px solid #888; padding: 1px;\">Unit Price</th>\n                        </tr>\n                    </thead>\n        \n                    <tbody> \n                        {% set shareholding = doc.get_shareholding_data() %}\n                        {% if shareholding and shareholding|length > 0 %}\n                            {% for m in shareholding %}\n                            <tr>\n                                <td style=\"border: 1px solid #888; padding: 1px;\">{{ m.firm_name or 'N/A' }}</td>\n                                <td style=\"border: 1px solid #888; padding: 1px;\">{{ m.unit or 'N/A' }}</td>\n                                <td style=\"border: 1px solid #888; padding: 1px;\">{{ m.type or 'N/A' }}</td>\n                                <td style=\"border: 1px solid #888; padding: 1px;\">{{ m.uniprice or 'N/A' }}</td>\n                            </tr>\n                            {% endfor %}\n                        {% else %}\n                            <tr>\n                                <td colspan=\"4\" style=\"text-align: center; border: 1px solid #888; padding: 5px;\">\n                                    No data found.\n                                </td>\n                            </tr>\n                            {% endif %}\n                    </tbody>\n                </table>\n                \n                <h5 class=\"mt-3 mb-2\">Property Tax</h5>\n                <table class=\"table table-bordered table-sm\" style=\"border-collapse: collapse; width:100%;\">\n                    <thead class=\"custom-dark\">\n                        <tr>\n                            <th style=\"border: 1px solid #888; padding: 1px;\">Business Name</th>\n                            <th style=\"border: 1px solid #888; padding: 1px;\">Business Sector</th>\n                            <th style=\"border: 1px solid #888; padding:1px;\">Business Size</th>\n                            <th style=\"border: 1px solid #888; padding: 1px;\">TurnOver</th>\n                            <th style=\"border: 1px solid #888; padding: 1px;\">Tax Paid</th>\n                            <th style=\"border: 1px solid #888; padding: 1px;\">Year</th>\n                            <th style=\"border: 1px solid #888; padding: 1px;\">Status</th>\n                        </tr>\n                    </thead>\n        \n                    <tbody> \n                        {% set property_tax = doc.get_property_tax() %}\n                        {% if property_tax and property_tax|length > 0 %}\n                            {% for m in property_tax %}\n                                <tr>\n                                    <td style=\"border: 1px solid #888; padding: 1px;\">{{ m.businessName or 'N/A' }}</td>\n                                    <td style=\"border: 1px solid #888; padding: 1px;\">{{ m.businessSector or 'N/A' }}</td>\n                                    <td style=\"border: 1px solid #888; padding: 1px;\">{{ m.businessSize or 'N/A' }}</td>\n                                    <td style=\"border: 1px solid #888; padding: 1px;\">{{ m.turnOver or 'N/A' }}</td>\n                                    <td style=\"border: 1px solid #888; padding: 1px;\">{{ m.taxPaid or 'N/A' }}</td>\n                                    <td style=\"border: 1px solid #888; padding: 1px;\">{{ m.year or 'N/A' }}</td>\n                                    <td style=\"border: 1px solid #888; padding: 1px;\">{{ m.status or 'N/A' }}</td>\n                \n                                </tr>\n                            {% endfor %}\n                        {% else %}\n                           <tr>\n                                <td colspan=\"7\" style=\"text-align: center; border: 1px solid #888; padding: 5px;\">\n                                    No data found.\n                                </td>\n                            </tr>\n                        {% endif %}\n                    </tbody>\n                </table>\n                \n                <h5 class=\"mt-3 mb-2\">Income Tax</h5>\n                <table class=\"table table-bordered table-sm\" style=\"border-collapse: collapse; width:100%;\">\n                    <thead class=\"custom-dark\">\n                        <tr>\n                            <th style=\"border: 1px solid #888; padding: 1px;\">Building Type</th>\n                            <th style=\"border: 1px solid #888; padding: 1px;\">Location</th>\n                            <th style=\"border: 1px solid #888; padding:1px;\">Rental Income</th>\n                            <th style=\"border: 1px solid #888; padding: 1px;\">Tax Paid</th>\n                            <th style=\"border: 1px solid #888; padding: 1px;\">Year</th>\n                            <th style=\"border: 1px solid #888; padding: 1px;\">Status</th>\n                        </tr>\n                    </thead>\n        \n                    <tbody> \n                        {% set rental_income = doc.get_rental_come() %}\n                        {% if rental_income and rental_income|length > 0 %}\n                            {% for m in rental_income %}\n                                <tr>\n                                    <td style=\"border: 1px solid #888; padding: 1px;\">{{ m.buildingType or 'N/A' }}</td>\n                                    <td style=\"border: 1px solid #888; padding: 1px;\">{{ m.location or 'N/A' }}</td>\n                                    <td style=\"border: 1px solid #888; padding: 1px;\">{{ m.rentalIncome or 'N/A' }}</td>\n                                    <td style=\"border: 1px solid #888; padding: 1px;\">{{ m.taxPaid or 'N/A' }}</td>\n                                    <td style=\"border: 1px solid #888; padding: 1px;\">{{ m.year or 'N/A' }}</td>\n                                    <td style=\"border: 1px solid #888; padding: 1px;\">{{ m.status or 'N/A' }}</td>\n                \n                                </tr>\n                            {% endfor %}\n                        {% else %}\n                           <tr>\n                                <td colspan=\"6\" style=\"text-align: center; border: 1px solid #888; padding: 5px;\">\n                                    No data found.\n                                </td>\n                            </tr>\n                        {% endif %}\n                    </tbody>\n                </table>\n                \n                <h5 class=\"mt-3 mb-2\">Vehicle</h5>\n                <table class=\"table table-bordered table-sm\" style=\"border-collapse: collapse; width:100%;\">\n                    <thead class=\"custom-dark\">\n                        <tr>\n                            <th style=\"border: 1px solid #888; padding: 1px;\">Make</th>\n                            <th style=\"border: 1px solid #888; padding: 1px;\">Model</th>\n                            <th style=\"border: 1px solid #888; padding:1px;\">Registration Date</th>\n                        </tr>\n                    </thead>\n        \n                    <tbody> \n                        {% set vehicle = doc.get_vehicle_detail() %}\n                        {% if vehicle and vehicle|length > 0 %}\n                            {% for m in vehicle %}\n                                <tr>\n                                    <td style=\"border: 1px solid #888; padding: 1px;\">{{ m.make or 'N/A' }}</td>\n                                    <td style=\"border: 1px solid #888; padding: 1px;\">{{ m.model or 'N/A' }}</td>\n                                    <td style=\"border: 1px solid #888; padding: 1px;\">{{ m.registrationDate or 'N/A' }}</td>\n        \n                                </tr>\n                            {% endfor %}\n                        {% else %}\n                           <tr>\n                                <td colspan=\"6\" style=\"text-align: center; border: 1px solid #888; padding: 5px;\">\n                                    No data found.\n                                </td>\n                            </tr>\n                        {% endif %}\n                    </tbody>\n                </table>\n            {% endif %}\n        {% endif %}\n        \n    </div>\n</body>\n\n</html>",
